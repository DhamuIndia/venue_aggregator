FROM node:22-alpine AS deps

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

FROM node:22-alpine AS builder

WORKDIR /app

ARG NEXT_PUBLIC_API_BASE_URL
ARG NEXT_PUBLIC_AUTH_MODE=api
ARG NEXT_PUBLIC_HALLS_MODE=api
ARG NEXT_PUBLIC_ENQUIRIES_MODE=api
ARG NEXT_PUBLIC_AVAILABILITY_MODE=api
ARG NEXT_PUBLIC_OWNER_LISTINGS_MODE=api
ARG NEXT_PUBLIC_OWNER_ONBOARDING_MODE=api
ARG NEXT_PUBLIC_OWNER_MEDIA_MODE=api
ARG NEXT_PUBLIC_OWNER_REVIEWS_MODE=api
ARG NEXT_PUBLIC_CUSTOMER_REVIEWS_MODE=api
ARG NEXT_PUBLIC_CUSTOMER_SAVED_HALLS_MODE=api
ARG NEXT_PUBLIC_BOOKINGS_MODE=api
ARG NEXT_PUBLIC_BOOKING_PAYMENTS_MODE=api
ARG NEXT_PUBLIC_NOTIFICATIONS_MODE=api
ARG NEXT_PUBLIC_ANALYTICS_MODE=api
ARG NEXT_PUBLIC_VENDOR_LEADS_MODE=api
ARG NEXT_PUBLIC_ADMIN_MODE=api
ARG NEXT_PUBLIC_VENDORS_MODE=api
ARG NEXT_PUBLIC_VENDOR_PROFILE_MODE=api
ARG NEXT_PUBLIC_VENDOR_SUBSCRIPTION_MODE=api
ARG NEXT_PUBLIC_VENDOR_PACKAGES_MODE=api
ARG NEXT_PUBLIC_VENDOR_MEDIA_MODE=api

ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_AUTH_MODE=$NEXT_PUBLIC_AUTH_MODE
ENV NEXT_PUBLIC_HALLS_MODE=$NEXT_PUBLIC_HALLS_MODE
ENV NEXT_PUBLIC_ENQUIRIES_MODE=$NEXT_PUBLIC_ENQUIRIES_MODE
ENV NEXT_PUBLIC_AVAILABILITY_MODE=$NEXT_PUBLIC_AVAILABILITY_MODE
ENV NEXT_PUBLIC_OWNER_LISTINGS_MODE=$NEXT_PUBLIC_OWNER_LISTINGS_MODE
ENV NEXT_PUBLIC_OWNER_ONBOARDING_MODE=$NEXT_PUBLIC_OWNER_ONBOARDING_MODE
ENV NEXT_PUBLIC_OWNER_MEDIA_MODE=$NEXT_PUBLIC_OWNER_MEDIA_MODE
ENV NEXT_PUBLIC_OWNER_REVIEWS_MODE=$NEXT_PUBLIC_OWNER_REVIEWS_MODE
ENV NEXT_PUBLIC_CUSTOMER_REVIEWS_MODE=$NEXT_PUBLIC_CUSTOMER_REVIEWS_MODE
ENV NEXT_PUBLIC_CUSTOMER_SAVED_HALLS_MODE=$NEXT_PUBLIC_CUSTOMER_SAVED_HALLS_MODE
ENV NEXT_PUBLIC_BOOKINGS_MODE=$NEXT_PUBLIC_BOOKINGS_MODE
ENV NEXT_PUBLIC_BOOKING_PAYMENTS_MODE=$NEXT_PUBLIC_BOOKING_PAYMENTS_MODE
ENV NEXT_PUBLIC_NOTIFICATIONS_MODE=$NEXT_PUBLIC_NOTIFICATIONS_MODE
ENV NEXT_PUBLIC_ANALYTICS_MODE=$NEXT_PUBLIC_ANALYTICS_MODE
ENV NEXT_PUBLIC_VENDOR_LEADS_MODE=$NEXT_PUBLIC_VENDOR_LEADS_MODE
ENV NEXT_PUBLIC_ADMIN_MODE=$NEXT_PUBLIC_ADMIN_MODE
ENV NEXT_PUBLIC_VENDORS_MODE=$NEXT_PUBLIC_VENDORS_MODE
ENV NEXT_PUBLIC_VENDOR_PROFILE_MODE=$NEXT_PUBLIC_VENDOR_PROFILE_MODE
ENV NEXT_PUBLIC_VENDOR_SUBSCRIPTION_MODE=$NEXT_PUBLIC_VENDOR_SUBSCRIPTION_MODE
ENV NEXT_PUBLIC_VENDOR_PACKAGES_MODE=$NEXT_PUBLIC_VENDOR_PACKAGES_MODE
ENV NEXT_PUBLIC_VENDOR_MEDIA_MODE=$NEXT_PUBLIC_VENDOR_MEDIA_MODE

COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN npm run build

FROM node:22-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

RUN addgroup -S nextjs && adduser -S nextjs -G nextjs

COPY --from=builder --chown=nextjs:nextjs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nextjs /app/.next/static ./.next/static

USER nextjs

EXPOSE 3000

CMD ["node", "server.js"]

COMPOSE_PROJECT_NAME=bookvenuemart

APP_DOMAIN=bookvenuemart.in
API_DOMAIN=api.bookvenuemart.in
MEDIA_DOMAIN=media.bookvenuemart.in
ACME_EMAIL=admin@bookvenuemart.in

NEXT_PUBLIC_API_BASE_URL=https://api.bookvenuemart.in/api/v1

POSTGRES_DB=venue_aggregator
POSTGRES_USER=venue_app
POSTGRES_PASSWORD=replace-with-strong-postgres-password

MINIO_ROOT_USER=venue_minio
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
MINIO_BUCKET=venue-media

JWT_SECRET=replace-with-64-plus-character-random-secret
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000
CORS_ALLOWED_ORIGINS=https://bookvenuemart.in,https://www.bookvenuemart.in

MEDIA_MAX_UPLOAD_SIZE_BYTES=10485760
